{
  "name": "Detect_NoSQL_Injection",
  "search": "index=api_logs | eval uri=urldecode(uri_path) | where match(uri, \"\\\\{\\\\$ne:|\\\\{\\\\$gt:|\\\\{\\\\$where:\")",
  "description": "Detects NoSQL injection attempts ($ne, $gt)",
  "cron_schedule": "*/10 * * * *",
  "earliest_time": "-10m",
  "latest_time": "now"
}
