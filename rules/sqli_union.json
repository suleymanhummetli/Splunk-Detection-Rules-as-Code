{
  "name": "Detect_SQL_Injection_Union",
  "search": "index=api_logs | eval uri=urldecode(uri_path) | where match(uri, \"(?i)union\\\\s+all\\\\s+select|union\\\\s+select\")",
  "description": "Detects SQL Union-based injection attacks",
  "earliest_time": "-15m",
  "latest_time": "now",
  "cron_schedule": "*/1 * * * *",
  "alert.suppress": "0",
  "alert.digest_mode": "0",
  "action.script.filename": "sdp_ticket.py"
}
