{
  "name": "Detect_SQL_Injection_Blind",
  "search": "index=api_logs | eval uri=urldecode(uri_path) | where match(uri, \"(?i)sleep\\\\(|benchmark\\\\(|pg_sleep\\\\(\")",
  "description": "Detects time-based blind SQL injection,Uptade",
  "cron_schedule": "*/5 * * * *",
  "earliest_time": "-5m",
  "latest_time": "now"
}
