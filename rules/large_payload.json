{
  "name": "Detect_NoSQL_Injection",
  "search": "index=api_logs | eval uri=urldecode(uri_path) | where match(uri, \"\\\\{\\\\$ne:|\\\\{\\\\$gt:|\\\\{\\\\$where:\")",
  "description": "Detects NoSQL injection attempts ($ne, $gt, $where)",
  "earliest_time": "-15m",
  "latest_time": "now",
  "cron_schedule": "*/1 * * * *",
  "alert.suppress": "0",
  "alert.digest_mode": "0",
  "action.script.filename": "sdp_ticket.py"
}
