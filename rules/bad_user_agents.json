{
  "name": "Detect_Scanning_Tools",
  "search": "index=api_logs | where match(user_agent, \"(?i)sqlmap|nmap|nikto|dirbuster|gobuster|python-requests\")",
  "description": "Detects common hacking and scanning tools via User-Agent",
  "earliest_time": "-15m",
  "latest_time": "now",
  "cron_schedule": "*/1 * * * *",
  "alert.suppress": "0",
  "alert.digest_mode": "0",
  "action.script.filename": "sdp_ticket.py"
}
