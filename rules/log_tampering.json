{
  "name": "Detect_Log_Tampering_Attempts",
  "search": "index=api_logs | where match(uri_path, \"truncate|clear|delete\\\\s+from\\\\s+logs\")",
  "description": "Detects attempts to clear or tamper with logs via web",
  "earliest_time": "-30m",
  "latest_time": "now",
  "cron_schedule": "*/5 * * * *",
  "alert.suppress": "0",
  "alert.digest_mode": "0",
  "action.script.filename": "sdp_ticket.py"
}
